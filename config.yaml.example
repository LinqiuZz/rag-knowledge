# ============================================================
#  个人知识库系统 — 配置示例
#  复制为 config.yaml 后修改
# ============================================================

llm:
  default: claude                    # claude | ollama

  claude:
    model: mimo-v2.5-pro
    base_url: https://token-plan-cn.xiaomimimo.com/anthropic
    # api_key 通过 .env 文件或环境变量 ANTHROPIC_AUTH_TOKEN 设置

  ollama:
    model: qwen2.5:7b
    url: http://localhost:11434

embedding:
  model_name: BAAI/bge-small-zh-v1.5
  device: cuda                       # cpu | cuda
  dimension: 512

chunking:
  size: 512
  overlap: 64

store:
  chroma_path: data/db/chroma

mysql:
  host: localhost
  port: 3306
  user: Lin
  # password 通过 .env 文件或环境变量 MYSQL_PASSWORD 设置
  database: rag_meta

ingest:
  raw_dir: data/raw
  max_file_size_mb: 50
