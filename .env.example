# ============================================================
#  RAG 知识库系统 - 环境变量配置
#  复制此文件为 .env 并填入实际值
# ============================================================

# Claude API 配置 (二选一)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=rag_meta
